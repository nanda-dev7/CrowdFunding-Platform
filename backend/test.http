@baseUrl = http://localhost:5000
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZmM1ZTYzY2UxNTI4YzNjYTJhNTIyYiIsInJvbGUiOiJhZG1pbiIsImlhdCI6MTc3ODIyNjQ4MywiZXhwIjoxNzc4MjI3MzgzfQ.UPiJl3JySD2hUGMCc9acKVfx2SvVhH1iJD4nQFSQTgM
@adminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZmM1ZTYzY2UxNTI4YzNjYTJhNTIyYiIsInJvbGUiOiJhZG1pbiIsImlhdCI6MTc3ODIyNDgyOSwiZXhwIjoxNzc4MjI1NzI5fQ.4BdVntJVht3YhQhdTi7qao4ghsozclir1RYdLjx7bFM
@campaignId = 69fd8271893562a80e044329
@donationId = <donation_id_here>
@campaignerRequestId = <campaigner_request_id_here>
@notificationId = <notification_id_here>
@userId = <user_id_here>

### Health Check
GET {{baseUrl}}/health

### Register User
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "Test donor1",
  "email": "testdonor1@example.com",
  "password": "donor1123!",
  "role": "donor"
}

### Login User
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "testadmin1@example.com",
  "password": "admin1123!"
}

### Get Current User
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{authToken}}

### Refresh Token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Logout User
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{authToken}}

### List Campaigns
GET {{baseUrl}}/api/campaigns

### List Urgent Campaigns
GET {{baseUrl}}/api/campaigns/urgent

### Get Campaign by ID
GET {{baseUrl}}/api/campaigns/{{campaignId}}

### Create Campaign (Campaigner/Admin only)
POST {{baseUrl}}/api/campaigns
Authorization: Bearer {{authToken}}

@title=Test Campaign2
@description=This is a sample campaign2 created during backend testing.
@goalAmount=20000
@deadline=2026-12-30
@category=Emergency
@coverImage=./assets/test-image.jpg

### Update Campaign (Campaigner/Admin only)
PUT {{baseUrl}}/api/campaigns/{{campaignId}}
Authorization: Bearer {{authToken}}

title=Updated Campaign Title
description=Updated description for the campaign.
urgencyLevel=critical
coverImage=@./assets/new-cover.jpg

### Add Campaign Update (Campaigner/Admin only)
POST {{baseUrl}}/api/campaigns/{{campaignId}}/updates
Authorization: Bearer {{authToken}}

@stage=during
@text=First update for campaign testing.
@image=./assets/update-image.jpg


### Upload Medical Document (Campaigner/Admin only)
POST {{baseUrl}}/api/campaigns/{{campaignId}}/medical-documents
Authorization: Bearer {{authToken}}

@document=./assets/medical.pdf

### Delete Medical Document (Campaigner/Admin only)
DELETE {{baseUrl}}/api/campaigns/{{campaignId}}/medical-documents/<document_id_here>
Authorization: Bearer {{authToken}}

### Create Donation Order
POST {{baseUrl}}/api/donations/create-order
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "campaignId": "{{campaignId}}",
  "amount": 500
}

### Confirm Donation Payment
POST {{baseUrl}}/api/donations/confirm
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "donationId": "{{donationId}}",
  "razorpayPaymentId": "<razorpay_payment_id>",
  "razorpaySignature": "<razorpay_signature>"
}

### Get My Donations
GET {{baseUrl}}/api/donations/me
Authorization: Bearer {{authToken}}

### Get Notifications
GET {{baseUrl}}/api/notifications
Authorization: Bearer {{authToken}}

### Mark Notification as Read
PUT {{baseUrl}}/api/notifications/{{notificationId}}/read
Authorization: Bearer {{authToken}}

### Apply as Campaigner
POST {{baseUrl}}/api/campaigner/apply
Authorization: Bearer {{authToken}}

@bio=I would like to become a campaigner to support causes.
@document=./assets/document.pdf

### Get Campaigner Status
GET {{baseUrl}}/api/campaigner/status
Authorization: Bearer {{authToken}}

### Get Campaigner Dashboard
GET {{baseUrl}}/api/campaigner/dashboard
Authorization: Bearer {{authToken}}

### Get My Coupons
GET {{baseUrl}}/api/users/me/coupons
Authorization: Bearer {{authToken}}

### Get Donor Dashboard
GET {{baseUrl}}/api/users/me/dashboard
Authorization: Bearer {{authToken}}

### Get My Donations from Dashboard
GET {{baseUrl}}/api/users/me/donations
Authorization: Bearer {{authToken}}

### Admin: Get Campaigner Requests
GET {{baseUrl}}/api/admin/campaigner-requests
Authorization: Bearer {{adminToken}}

### Admin: Approve Campaigner
PUT {{baseUrl}}/api/admin/campaigner/{{campaignerRequestId}}/approve
Authorization: Bearer {{adminToken}}

### Admin: Reject Campaigner
PUT {{baseUrl}}/api/admin/campaigner/{{campaignerRequestId}}/reject
Authorization: Bearer {{adminToken}}

### Admin: Get Pending Campaigns
GET {{baseUrl}}/api/admin/campaigns/pending
Authorization: Bearer {{adminToken}}

### Admin: Approve Campaign
PUT {{baseUrl}}/api/admin/campaigns/{{campaignId}}/approve
Authorization: Bearer {{adminToken}}

### Admin: Reject Campaign
PUT {{baseUrl}}/api/admin/campaigns/{{campaignId}}/reject
Authorization: Bearer {{adminToken}}

### Admin: Mark Campaign Urgent
PUT {{baseUrl}}/api/admin/campaigns/{{campaignId}}/urgent
Authorization: Bearer {{adminToken}}

### Admin: Get Stats
GET {{baseUrl}}/api/admin/stats
Authorization: Bearer {{adminToken}}

### Admin: Get All Users
GET {{baseUrl}}/api/admin/users
Authorization: Bearer {{adminToken}}

### Admin: Change User Role
PUT {{baseUrl}}/api/admin/users/{{userId}}/role
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "role": "campaigner"
}
